{
  "name": "ETL_Student_Analytics_Pipeline",
  "timeout_seconds": 3600,
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "01_data_ingestion",
      "description": "Read CSV from DBFS, validate schema and data quality",
      "notebook_task": {
        "notebook_path": "/soa-student-analytics/01_ingestion/01_data_ingestion",
        "source": "WORKSPACE"
      },
      "existing_cluster_id": "<YOUR_CLUSTER_ID>"
    },
    {
      "task_key": "02_bronze_layer",
      "description": "Save raw data to Delta Lake Bronze",
      "depends_on": [{ "task_key": "01_data_ingestion" }],
      "notebook_task": {
        "notebook_path": "/soa-student-analytics/02_bronze/02_bronze_layer",
        "source": "WORKSPACE"
      },
      "existing_cluster_id": "<YOUR_CLUSTER_ID>"
    },
    {
      "task_key": "03_silver_layer",
      "description": "Clean data, compute total_score and grade_10 → Silver",
      "depends_on": [{ "task_key": "02_bronze_layer" }],
      "notebook_task": {
        "notebook_path": "/soa-student-analytics/03_silver/03_silver_layer",
        "source": "WORKSPACE"
      },
      "existing_cluster_id": "<YOUR_CLUSTER_ID>"
    },
    {
      "task_key": "04_gold_analytics",
      "description": "Compute GPA, letter grades, at_risk flag → Gold",
      "depends_on": [{ "task_key": "03_silver_layer" }],
      "notebook_task": {
        "notebook_path": "/soa-student-analytics/04_gold/04_gold_analytics",
        "source": "WORKSPACE"
      },
      "existing_cluster_id": "<YOUR_CLUSTER_ID>"
    }
  ],
  "job_clusters": [],
  "format": "MULTI_TASK"
}
